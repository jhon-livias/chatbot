        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('contentType video', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.contentType).to.eql('video');",
              "    pm.expect(json.messageId).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{agent_token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "content", "value": "Video informativo", "type": "text" },
            { "key": "file", "type": "file", "src": "", "description": "Selecciona .mp4 (video/mp4)" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/conversations/{{conversation_id}}/messages",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "conversations", "{{conversation_id}}", "messages"]
        },
        "description": "A5 outbound — Agente envía video MP4 al lead. multipart/form-data. Máx 16 MB."
      },
      "response": []
    },
    {
      "name": "POST /webhook — Status update (ignored, 200)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const secret = pm.environment.get('webhook_secret');",
              "const rawBody = pm.variables.replaceIn(pm.request.body.raw);",
              "const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
              "pm.request.headers.upsert({ key: 'x-hub-signature-256', value: 'sha256=' + signature });",
              "pm.request.body.update(rawBody);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
