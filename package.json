{
  "name": "chatbot-uprit",
  "version": "1.0.0",
  "description": "Chatbot backend — Clean Architecture con DeepSeek AI, Meta WhatsApp API y MongoDB",
  "author": "UPRIT",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node --env-file=.env dist/main.js",
    "dev": "node --watch --env-file=.env --experimental-strip-types src/main.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "seed": "node --env-file=.env dist/infrastructure/database/mongodb/seeders/run-seeders.js",
    "seed:dev": "node --watch --env-file=.env --experimental-strip-types src/infrastructure/database/mongodb/seeders/run-seeders.ts",
    "docker:build": "docker compose build --no-cache",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:down:v": "docker compose down -v",
    "docker:logs": "docker compose logs -f app",
    "docker:logs:obs": "docker compose logs -f loki promtail grafana",
    "docker:logs:all": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart app",
    "docker:exec": "docker compose exec app sh"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "handlebars": "^4.7.9",
    "mongoose": "^8.16.1",
    "pino": "^9.7.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.29.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.8.3"
  }
}
