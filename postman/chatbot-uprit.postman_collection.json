        "description": "Verifica que payloads sin firma HMAC válida sean rechazados."
      },
      "response": []
    },
    {
      "name": "POST /webhook — Status update (ignored, 200)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const secret = pm.environment.get('webhook_secret');",
              "const rawBody = pm.variables.replaceIn(pm.request.body.raw);",
              "const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
              "pm.request.headers.upsert({ key: 'x-hub-signature-256', value: 'sha256=' + signature });",
              "pm.request.body.update(rawBody);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"WHATSAPP_BUSINESS_ACCOUNT_ID\",\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"15551234567\",\n              \"phone_number_id\": \"1234567890\"\n            },\n            \"statuses\": [\n              {\n                \"id\": \"wamid.postman.status.001\",\n                \"status\": \"delivered\",\n                \"timestamp\": \"1719900001\",\n                \"recipient_id\": \"{{test_wa_id}}\"\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "https://chatbot.uprit.edu.pe/webhook",
          "protocol": "https",
          "host": ["chatbot", "uprit", "edu", "pe"],
          "path": ["webhook"]
        },
        "description": "Actualizaciones de estado (delivered/read). El servidor responde 200 pero no procesa el evento."
      },
      "response": []
    }
  ]
