    {
      "name": "POST /webhook — Text message",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const secret = pm.environment.get('webhook_secret');",
              "",
              "if (!secret || secret.startsWith('TU_')) {",
              "    console.warn('Configura webhook_secret en el environment (WEBHOOK_SECRET del .env).');",
              "}",
              "",
              "const rawBody = pm.variables.replaceIn(pm.request.body.raw);",
              "const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
              "",
              "pm.request.headers.upsert({",
              "    key: 'x-hub-signature-256',",
              "    value: 'sha256=' + signature",
              "});",
              "",
              "pm.request.body.update(rawBody);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('Responde rápido (Meta exige 200)', () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"WHATSAPP_BUSINESS_ACCOUNT_ID\",\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"15551234567\",\n              \"phone_number_id\": \"1234567890\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": { \"name\": \"Postman Test\" },\n                \"wa_id\": \"{{test_wa_id}}\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"{{test_wa_id}}\",\n                \"id\": \"wamid.postman.test.001\",\n                \"timestamp\": \"1719900000\",\n                \"type\": \"text\",\n                \"text\": { \"body\": \"{{test_message}}\" }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "https://chatbot.uprit.edu.pe/webhook",
          "protocol": "https",
          "host": ["chatbot", "uprit", "edu", "pe"],
          "path": ["webhook"]
        },
        "description": "Simula un mensaje de texto entrante de WhatsApp en producción.\n\nEl pre-request script firma el body con `WEBHOOK_SECRET`.\n\n**Nota:** dispara el flujo real (IA + respuesta WhatsApp)."
      },
      "response": []
    },
