    {
      "name": "GET /webhook — Meta verification",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('Returns hub.challenge', () => {",
              "    pm.expect(pm.response.text()).to.eql(pm.environment.get('webhook_challenge'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://chatbot.uprit.edu.pe/webhook?hub.mode=subscribe&hub.verify_token={{meta_webhook_verify_token}}&hub.challenge={{webhook_challenge}}",
          "protocol": "https",
          "host": ["chatbot", "uprit", "edu", "pe"],
          "path": ["webhook"],
          "query": [
            { "key": "hub.mode", "value": "subscribe" },
            { "key": "hub.verify_token", "value": "{{meta_webhook_verify_token}}" },
            { "key": "hub.challenge", "value": "{{webhook_challenge}}" }
          ]
        },
        "description": "Handshake de Meta (mismo flujo que al conectar el webhook en Meta Developers).\n\nRequiere `meta_webhook_verify_token` = `META_WEBHOOK_VERIFY_TOKEN` del servidor."
      },
      "response": []
    },
