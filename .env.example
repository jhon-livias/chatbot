# ──────────────────────────────────────────────
#  ENTORNO DE EJECUCIÓN
# ──────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000                     # Puerto interno del contenedor / servidor Node
API_PORT=8090                 # Puerto expuesto en el host (Docker) — Tomcat usa 8080, Grafana usa 3000
LOG_LEVEL=debug               # fatal | error | warn | info | debug | trace
SERVICE_NAME=chatbot-uprit

# ──────────────────────────────────────────────
#  BASE DE DATOS — MONGODB
# ──────────────────────────────────────────────
# LOCAL:  mongodb://localhost:27017/chatbot_uprit
# ATLAS:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=chatbot_uprit
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# ──────────────────────────────────────────────
#  IA — DEEPSEEK
# ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash   # deepseek-chat | deepseek-reasoner | deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=2048
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_REQUEST_TIMEOUT_MS=30000
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RETRY_BASE_DELAY_MS=500

# ──────────────────────────────────────────────
#  WEBHOOK — META WHATSAPP API
# ──────────────────────────────────────────────
META_WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxx
META_WHATSAPP_PHONE_NUMBER_ID=1234567890
META_WHATSAPP_BUSINESS_ACCOUNT_ID=0987654321
META_WEBHOOK_VERIFY_TOKEN=mi_token_secreto_verificacion   # GET /webhook — lo defines tú en Meta Developers
META_API_VERSION=v20.0
META_API_BASE_URL=https://graph.facebook.com

# ──────────────────────────────────────────────
#  SEGURIDAD
# ──────────────────────────────────────────────
# App Secret de Meta (32 hex) — NO es el verify token. Firma POST /webhook (x-hub-signature-256).
WEBHOOK_SECRET=00000000000000000000000000000000
CORS_ORIGINS=http://localhost:3000,https://tudominio.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────────
#  MEDIA — ALMACENAMIENTO LOCAL (M1)
# ──────────────────────────────────────────────
# Directorio donde se guardan los archivos recibidos/enviados (Docker volume)
MEDIA_STORAGE_PATH=/app/uploads
# URL base pública para acceder a la media (proxy Nginx /media → backend)
MEDIA_PUBLIC_BASE_URL=https://admision.uprit.edu.pe/media
# Auto-reply cuando el lead envía imagen/PDF en modo bot (sin DeepSeek)
AUTO_REPLY_UNSUPPORTED_MEDIA=Recibí tu archivo. Por favor cuéntame en texto tu consulta o espera a un asesor.

# ──────────────────────────────────────────────
#  LOCATION — UPRIT SEDE (A7 outbound default)
# ──────────────────────────────────────────────
LOCATION_LATITUDE=-8.1116
LOCATION_LONGITUDE=-79.0285
LOCATION_NAME=UPRIT - Sede Trujillo
LOCATION_ADDRESS=Av. América Sur 2555, Trujillo, La Libertad

# ──────────────────────────────────────────────
#  BOT MENU — INTERACTIVE HANDOFF (F8 / M10)
# ──────────────────────────────────────────────
# true → handoff Sí/No como botones WhatsApp; false → texto (Sí/No)
INTERACTIVE_HANDOFF=false

# ──────────────────────────────────────────────
#  HUMAN HANDOFF — PANEL ASESORES
# ──────────────────────────────────────────────
ADMISION_PANEL_URL=https://admision.uprit.edu.pe
HANDOFF_TRANSITION_MESSAGE=Te comunico con {agentName}, asesor de admisiones de la UPRIT. En un momento te atiende.

# ──────────────────────────────────────────────
#  AUTH JWT — AGENTES
# ──────────────────────────────────────────────
# Producción: generar secreto único (openssl rand -base64 48)
JWT_SECRET=genera-un-secreto-largo-aleatorio-minimo-32-chars
JWT_EXPIRES_IN=8h
# CORS para panel en admision.uprit.edu.pe (dev: http://localhost:5173 ya incluido en main.ts)
ADMISION_CORS_ORIGIN=https://admision.uprit.edu.pe

# ──────────────────────────────────────────────
#  OBSERVABILIDAD — GRAFANA + LOKI
# ──────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia_esta_contraseña
GRAFANA_ROOT_URL=https://grafana.uprit.edu.pe
