# ──────────────────────────────────────────────
#  ENTORNO DE EJECUCIÓN
# ──────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000                     # Puerto interno del contenedor / servidor Node
API_PORT=8090                 # Puerto expuesto en el host (Docker) — Tomcat usa 8080, Grafana usa 3000
LOG_LEVEL=debug               # fatal | error | warn | info | debug | trace
SERVICE_NAME=chatbot-uprit

# ──────────────────────────────────────────────
#  BASE DE DATOS — MONGODB
# ──────────────────────────────────────────────
# LOCAL:  mongodb://localhost:27017/chatbot_uprit
# ATLAS:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=chatbot_uprit
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# ──────────────────────────────────────────────
#  IA — DEEPSEEK
# ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash   # deepseek-chat | deepseek-reasoner | deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=2048
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_REQUEST_TIMEOUT_MS=30000
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RETRY_BASE_DELAY_MS=500

# ──────────────────────────────────────────────
#  WEBHOOK — META WHATSAPP API
# ──────────────────────────────────────────────
META_WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxx
META_WHATSAPP_PHONE_NUMBER_ID=1234567890
META_WHATSAPP_BUSINESS_ACCOUNT_ID=0987654321
META_WEBHOOK_VERIFY_TOKEN=mi_token_secreto_verificacion   # GET /webhook — lo defines tú en Meta Developers
META_API_VERSION=v20.0
META_API_BASE_URL=https://graph.facebook.com

# ──────────────────────────────────────────────
#  SEGURIDAD
# ──────────────────────────────────────────────
# App Secret de Meta (32 hex) — NO es el verify token. Firma POST /webhook (x-hub-signature-256).
WEBHOOK_SECRET=00000000000000000000000000000000
CORS_ORIGINS=http://localhost:3000,https://tudominio.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────────
#  OBSERVABILIDAD — GRAFANA + LOKI
# ──────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia_esta_contraseña
GRAFANA_ROOT_URL=https://grafana.uprit.edu.pe
